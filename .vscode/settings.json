{
    "java.configuration.updateBuildConfiguration": "automatic",
    "[java]": {
        "editor.formatOnSave": false
    },
    "emeraldwalk.runonsave": {
        "commands": [
            {
                "match": "\\.java$",
                "cmd": "python3 \"${workspaceFolder}/.java-coding-standards/tooling/scripts/format_file.py\" \"${file}\""
            }
        ]
    }
}
